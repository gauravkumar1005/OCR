# ==========================
# OCR Engine
# ==========================
HOST=0.0.0.0
PORT=8001
DEBUG=False

# ==========================
# Backend
# ==========================
OCR_ENGINE_URL=http://127.0.0.1:8001
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
CALLBACK_TIMEOUT=60
OCR_CALLBACK_METHOD=PATCH

# ==========================
# OCR Processing
# ==========================
# Leave empty to process all pages. Set a positive number to limit pages.
OCR_PDF_PATH=TEST_PDF/MEDSAVE.pdf
MAX_PDF_PAGES=
SAVE_INTERMEDIATE_RESULTS=true
SAVE_FINAL_PAYLOAD=true

# ==========================
# Logging
# ==========================
LOG_LEVEL=INFO
OCR_RESULT_ROOT=RESULT

# ==========================
# Vision / LLM (only if used)
# ==========================
OPENAI_API_KEY=
OPENAI_MODEL=
GOOGLE_API_KEY=
GOOGLE_MODEL=

# ==========================
# File Paths
# ==========================
RESULT_DIR=RESULT
TEMP_DIR=TEMP

# ==========================
# Groq / LLM (only if used)
# ==========================
GROQ_API_KEY=

# ==========================
# Model server (optional - see model_server.py)
# ==========================
# If set, main.py's per-job subprocess calls this persistent server for
# YOLO layout detection / EDSR super-resolution instead of loading those
# models itself each time. Leave empty to keep the old per-job behavior.
# Run the server separately: python model_server.py
OCR_MODEL_SERVER_URL=
OCR_MODEL_SERVER_TIMEOUT_SECONDS=60
MODEL_SERVER_PORT=9100

# ==========================
# Background cleanup (api.py)
# ==========================
# Deletes RESULT/<run>/ folders, runs/<run_id>.json progress files, and
# temp/ contents older than this many days. Set to 0 to disable.
OCR_CLEANUP_RETENTION_DAYS=7
OCR_CLEANUP_INTERVAL_SECONDS=21600
