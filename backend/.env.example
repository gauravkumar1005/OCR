# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=claims_db

# Cloudinary (only needed if using /uploads/cloudinary-signature)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OCR engine (only needed if backend itself calls the engine)
OCR_ENGINE_URL=http://localhost:9000
BACKEND_PUBLIC_URL=http://localhost:8000

# App
APP_NAME=Claim OCR Backend
ENV=development
CORS_ORIGINS=["*"]

# Auth / JWT - MUST override these in production
JWT_SECRET_KEY=change-this-secret-key-in-env-file
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Shared secret the OCR engine uses to call back /claims/{id}/documents/callback
# (machine-to-machine, not a user JWT) - MUST override in production
OCR_CALLBACK_SECRET=change-this-ocr-callback-secret
